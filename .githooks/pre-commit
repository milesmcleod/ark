#!/bin/sh
set -e

echo "Running pre-commit checks..."

# Auto-format and re-stage changed files
echo "  fmt..."
cargo fmt 2>&1
git diff --name-only --diff-filter=M | while read -r file; do
    case "$file" in *.rs) git add "$file" ;; esac
done

# Clippy
echo "  clippy..."
cargo clippy -- -D warnings 2>&1 || {
    echo "Clippy failed. Fix warnings above."
    exit 1
}

# Tests
echo "  tests..."
cargo test --quiet 2>&1 || {
    echo "Tests failed. Fix failures above."
    exit 1
}

echo "Pre-commit checks passed."
